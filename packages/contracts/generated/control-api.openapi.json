{
  "openapi": "3.1.0",
  "info": {
    "title": "Symphony Encore Control API",
    "version": "0.0.0"
  },
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "in": "cookie",
        "name": "symphony_session",
        "type": "apiKey"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Process liveness",
        "tags": [
          "service"
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "service_state",
                    "status"
                  ],
                  "properties": {
                    "service_state": {
                      "anyOf": [
                        {
                          "type": "string",
                          "enum": [
                            "starting"
                          ]
                        },
                        {
                          "type": "string",
                          "enum": [
                            "recovering"
                          ]
                        },
                        {
                          "type": "string",
                          "enum": [
                            "ready"
                          ]
                        },
                        {
                          "type": "string",
                          "enum": [
                            "failed"
                          ]
                        }
                      ]
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "healthy"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "operationId": "getReady",
        "summary": "Service readiness",
        "tags": [
          "service"
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "service_run_id",
                    "status"
                  ],
                  "properties": {
                    "service_run_id": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "ready"
                      ]
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "error"
                  ],
                  "properties": {
                    "error": {
                      "additionalProperties": false,
                      "type": "object",
                      "required": [
                        "code",
                        "current_version",
                        "details",
                        "message"
                      ],
                      "properties": {
                        "code": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "current_version": {
                          "anyOf": [
                            {
                              "minLength": 1,
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "details": {
                          "type": "object",
                          "additionalProperties": {}
                        },
                        "message": {
                          "minLength": 1,
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/state": {
      "get": {
        "operationId": "getControlState",
        "summary": "Current orchestrator state",
        "tags": [
          "control"
        ],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "dispatch_enabled",
                    "mutations_enabled",
                    "service_run",
                    "version"
                  ],
                  "properties": {
                    "dispatch_enabled": {
                      "type": "boolean"
                    },
                    "mutations_enabled": {
                      "type": "boolean"
                    },
                    "service_run": {
                      "additionalProperties": false,
                      "type": "object",
                      "required": [
                        "id",
                        "service_version",
                        "started_at",
                        "status"
                      ],
                      "properties": {
                        "id": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "service_version": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "started_at": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "status": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "starting"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "recovering"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "ready"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "failed"
                              ]
                            }
                          ]
                        }
                      }
                    },
                    "version": {
                      "minLength": 1,
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "error"
                  ],
                  "properties": {
                    "error": {
                      "additionalProperties": false,
                      "type": "object",
                      "required": [
                        "code",
                        "current_version",
                        "details",
                        "message"
                      ],
                      "properties": {
                        "code": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "current_version": {
                          "anyOf": [
                            {
                              "minLength": 1,
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "details": {
                          "type": "object",
                          "additionalProperties": {}
                        },
                        "message": {
                          "minLength": 1,
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "error"
                  ],
                  "properties": {
                    "error": {
                      "additionalProperties": false,
                      "type": "object",
                      "required": [
                        "code",
                        "current_version",
                        "details",
                        "message"
                      ],
                      "properties": {
                        "code": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "current_version": {
                          "anyOf": [
                            {
                              "minLength": 1,
                              "type": "string"
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "details": {
                          "type": "object",
                          "additionalProperties": {}
                        },
                        "message": {
                          "minLength": 1,
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
