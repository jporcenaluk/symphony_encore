{
  "name": "symphony-encore",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "contracts:check": "node --conditions=development --import ./scripts/typescript-source-loader.mjs scripts/generate-contract-schemas.ts --check",
    "contracts:generate": "node --conditions=development --import ./scripts/typescript-source-loader.mjs scripts/generate-contract-schemas.ts",
    "format": "biome check --write .",
    "image": "docker build --tag symphony-encore:verify .",
    "lint": "biome check . && markdownlint-cli2 && node scripts/repository-policy.ts && pnpm contracts:check && pnpm openapi:check",
    "openapi:check": "node --conditions=development --import ./scripts/typescript-source-loader.mjs scripts/generate-openapi.ts --check",
    "openapi:generate": "node --conditions=development --import ./scripts/typescript-source-loader.mjs scripts/generate-openapi.ts",
    "policy": "node scripts/repository-policy.ts",
    "start": "pnpm --filter @symphony/server start",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:integration": "pnpm build && node --import ./scripts/typescript-source-loader.mjs scripts/verify-production-runtime.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r --if-present typecheck && tsc --noEmit -p tsconfig.scripts.json",
    "verify-fast": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@biomejs/biome": "2.5.3",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
