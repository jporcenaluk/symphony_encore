{
  "name": "symphony-encore",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "format": "biome check --write .",
    "lint": "biome check . && markdownlint-cli2 && node scripts/repository-policy.ts",
    "policy": "node scripts/repository-policy.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r --if-present typecheck && tsc --noEmit -p tsconfig.scripts.json",
    "verify-fast": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
