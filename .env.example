# Trusted startup paths. Relative paths resolve from the process working directory.
SYMPHONY_WORKFLOW_PATH=WORKFLOW.md
SYMPHONY_DATABASE_PATH=.symphony/symphony.sqlite3
SYMPHONY_WORKSPACE_ROOT=.symphony/workspaces
SYMPHONY_UI_ROOT=apps/web/dist

# Loopback is the secure default. See docs/operations/security.md before changing it.
SYMPHONY_HOST=127.0.0.1
SYMPHONY_PORT=8080
SYMPHONY_ALLOW_NON_LOOPBACK=false
SYMPHONY_SECURE_COOKIES=false
SYMPHONY_SESSION_TTL_MS=28800000

# Supply both values only for a pristine database, then remove them after bootstrap.
SYMPHONY_BOOTSTRAP_AUTH_SUBJECT=
SYMPHONY_BOOTSTRAP_CREDENTIAL=

LOG_LEVEL=info
